FROM python:3.12-slim

WORKDIR /app

# System deps kept minimal; wheels cover httpx/cachetools/mcp/uvicorn on py3.12.
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

EXPOSE 8000

# Backend API (includes the OSINT /osint/lookup + /ws/osint routes). The MCP server runs separately:
#   python -m app.mcp_server
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
